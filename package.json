{
  "name": "texgen",
  "version": "1.0.0",
  "description": "A lightweight procedural texture generation library using GLSL.",
  "main": "./dist/texgen.js",
  "module": "./dist/texgen.mjs",
  "types": "./dist/texgen.d.ts",
  "exports": {
    ".": {
      "types": "./dist/texgen.d.ts",
      "import": "./dist/texgen.mjs",
      "require": "./dist/texgen.js"
    }
  },
  "bin": {
    "texgen": "./bin/cli.js"
  },
  "files": [
    "dist",
    "src",
    "bin",
    "README_LIB.md"
  ],
  "scripts": {
    "build": "make build",
    "test": "npm run build && vitest run",
    "start": "npx http-server -p 8080",
    "setup": "npm install",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tonym128/texgen.git"
  },
  "bugs": {
    "url": "https://github.com/tonym128/texgen/issues"
  },
  "homepage": "https://github.com/tonym128/texgen#readme",
  "keywords": [
    "procedural",
    "texture",
    "glsl",
    "webgl",
    "generator",
    "gamedev"
  ],
  "author": "Tony Mamacos <tmamacos@gmail.com>",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "esbuild": "^0.27.3",
    "http-server": "^14.1.1",
    "jsdom": "^28.1.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "canvas": "^3.2.1",
    "gl": "^8.1.6"
  }
}
